# Copie este arquivo para .env e preencha apenas as variáveis que fizerem sentido
# para o seu ambiente. Nunca versionar o arquivo .env com chaves reais.

DOCLING_HOST_PORT=8010
PYTHONUNBUFFERED=1

# Ollama (opcional)
OLLAMA_BASE_URL=http://host.docker.internal:11434
OLLAMA_TEXT_MODEL=qwen3:8b
OLLAMA_VISION_MODEL=llava

# OpenAI (opcional)
OPENAI_API_KEY=
OPENAI_TEXT_API_KEY=
OPENAI_TEXT_MODEL=gpt-5.4-mini
OPENAI_VISION_API_KEY=
OPENAI_VISION_MODEL=gpt-5.4-mini

# Anthropic (opcional)
ANTHROPIC_API_KEY=
ANTHROPIC_TEXT_API_KEY=
ANTHROPIC_TEXT_MODEL=claude-sonnet-4-20250514
ANTHROPIC_VISION_API_KEY=
ANTHROPIC_VISION_MODEL=claude-sonnet-4-20250514

# Ajustes do enhancement por LLM
LLM_TIMEOUT=600
VISION_BATCH_SIZE=3
VISION_BATCH_SLEEP=10
LLM_MAX_RETRIES=3
LLM_MAX_TOKENS=16384
LLM_REMOVE_HEADERS_FOOTERS=true
ENHANCE_CHUNK_SIZE=8000
ENHANCE_CHUNK_SLEEP=5
